rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /meta/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /live_menu_items/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /live_cocktails/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /live_menu_notices/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /admin_draft_guide/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /admin_draft_spirits_public/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /admin_draft_menu_board_items/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /admin_draft_menu_board_tabs/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /admin_draft_cocktails/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /admin_draft_spirits/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /admin_draft_spirits_private/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /audit_logs/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
